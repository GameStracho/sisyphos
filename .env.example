# =============================================================================
# Sisyphos Documentation Website — Environment Configuration
# Copy this file to .env and fill in the real values.
# .env is git-ignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose profile to activate.
#   develop  — only the docs-website service (local preview, no tunnel)
#   public   — all services: docs-website + cloudflared + webhook-listener
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=public

# -----------------------------------------------------------------------------
# Port bindings on the host machine.
#   WEBSITE_PORT  — the port nginx listens on (e.g. open http://localhost:8080)
#   WEBHOOK_PORT  — the port the webhook listener binds to (for local testing)
#                   In production this is accessed through the CloudFlare tunnel,
#                   not exposed directly to the internet.
# -----------------------------------------------------------------------------
WEBSITE_PORT=8080
WEBHOOK_PORT=9000

# -----------------------------------------------------------------------------
# CloudFlare Zero Trust tunnel token.
# Required when COMPOSE_PROFILES=public.
#
# How to get it:
#   1. Go to https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
#   2. Create a new tunnel named e.g. "sisyphos-docs"
#   3. Copy the tunnel token shown in the install instructions
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# -----------------------------------------------------------------------------
# GitHub webhook secret.
# Required when COMPOSE_PROFILES=public.
#
# How to set it:
#   1. Generate a strong random string, e.g.:
#        openssl rand -hex 32
#   2. Paste the same value here AND in the GitHub webhook settings
#      (repo → Settings → Webhooks → your webhook → Secret)
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=your-webhook-secret-here
